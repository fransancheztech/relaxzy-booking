view bookings_with_details {
  booking_id                  String?          @db.Uuid
  booking_start_time          DateTime?        @db.Timestamptz(6)
  booking_end_time            DateTime?        @db.Timestamptz(6)
  booking_notes               String?
  booking_status              booking_status?
  booking_price               Decimal?         @db.Decimal
  booking_created_at          DateTime?        @db.Timestamptz(6)
  booking_updated_at          DateTime?        @db.Timestamptz(6)
  client_id                   String?          @db.Uuid
  client_name                 String?
  client_surname              String?
  client_email                String?
  client_phone                String?
  client_notes                String?
  client_created_at           DateTime?        @db.Timestamptz(6)
  service_id                  String?          @db.Uuid
  service_name                String?
  service_created_at          DateTime?        @db.Timestamptz(6)
  service_short_name          String?
  service_notes               String?
  service_deleted_at          DateTime?        @db.Timestamptz(6)
  service_duration_id         String?          @db.Uuid
  service_duration            Decimal?         @db.Decimal
  service_duration_notes      String?
  service_duration_created_at DateTime?        @db.Timestamptz(6)
  service_duration_deleted_at DateTime?        @db.Timestamptz(6)
  service_details_id          String?          @db.Uuid
  service_catalog_price       Decimal?         @db.Decimal
  service_details_notes       String?
  service_details_created_at  DateTime?        @db.Timestamptz(6)
  service_details_deleted_at  DateTime?        @db.Timestamptz(6)
  payment_id                  String?          @db.Uuid
  payment_amount              Decimal?         @db.Decimal(10, 2)
  payment_method              payment_methods?
  payment_refunded            Decimal?         @db.Decimal
  payment_refunded_at         DateTime?        @db.Timestamptz(6)
  payment_paid_at             DateTime?        @db.Timestamptz(6)
  payment_created_at          DateTime?        @db.Timestamptz(6)
  payment_notes               String?
}

view payment_events_summary {
  payment_id      String?          @db.Uuid
  charged_amount  Decimal?         @db.Decimal
  refunded_amount Decimal?         @db.Decimal
  paid_at         DateTime?        @db.Timestamptz(6)
  refunded_at     DateTime?        @db.Timestamptz(6)
  method          payment_methods?
}

view payments_summary {
  payment_id      String?          @db.Uuid
  booking_id      String?          @db.Uuid
  amount          Decimal?         @db.Decimal
  notes           String?
  created_at      DateTime?        @db.Timestamptz(6)
  method          payment_methods?
  paid_at         DateTime?        @db.Timestamptz(6)
  refunded_amount Decimal?         @db.Decimal
  refunded_at     DateTime?        @db.Timestamptz(6)
  voucher_id      String?          @db.Uuid
}

enum booking_status {
  pending
  confirmed
  cancelled
  completed
}

enum change_type {
  INSERT
  UPDATE
  DELETE
}

enum payment_methods {
  cash
  credit_card
}

enum payment_types {
  CHARGE
  REFUND
}
